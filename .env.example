# ============================================================
# CI/CD Pipeline Error Analysis AI Agent - Environment Config
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o               # or gpt-4, gpt-4-turbo

# ── GitHub ──────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token-here

# ── GitLab (optional) ───────────────────────────────────────
GITLAB_TOKEN=glpat-your-gitlab-token-here
GITLAB_URL=https://gitlab.com     # Change for self-hosted

# ── Jenkins (optional) ──────────────────────────────────────
JENKINS_URL=https://jenkins.yourcompany.com
JENKINS_USER=your-jenkins-username
JENKINS_API_TOKEN=your-jenkins-api-token

# ── Agent Behaviour ─────────────────────────────────────────
DEFAULT_BASE_BRANCH=main
MAX_FIX_ATTEMPTS=3
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
